{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "config",
          "theme",
          "custom-variant"
        ]
      }
    ],
    "selector-class-pattern": [
      "^[a-z][a-zA-Z0-9_-]*$",
      {
        "message": "Expected class selector to be kebab-case",
        "resolveNestedSelectors": true
      }
    ]
  }
}
